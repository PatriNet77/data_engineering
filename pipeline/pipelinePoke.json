{
	"name": "pipelinePoke",
	"properties": {
		"description": "De CSV a SQL",
		"activities": [
			{
				"name": "PokeAPI",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "DelimitedTextSource",
						"storeSettings": {
							"type": "AzureBlobStorageReadSettings",
							"recursive": true,
							"wildcardFileName": "Titanic-Dataset.csv",
							"enablePartitionDiscovery": false
						},
						"formatSettings": {
							"type": "DelimitedTextReadSettings"
						}
					},
					"sink": {
						"type": "AzureSqlSink",
						"writeBehavior": "upsert",
						"upsertSettings": {
							"useTempDB": true,
							"keys": [
								"PassengerId"
							]
						},
						"sqlWriterUseTableLock": false,
						"disableMetricsCollection": false
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"mappings": [
							{
								"source": {
									"name": "PassengerId",
									"type": "String",
									"physicalType": "String"
								},
								"sink": {
									"name": "PassengerId",
									"type": "Int32",
									"physicalType": "int"
								}
							},
							{
								"source": {
									"name": "Survived",
									"type": "String",
									"physicalType": "String"
								},
								"sink": {
									"name": "Survived",
									"type": "Boolean",
									"physicalType": "bit"
								}
							},
							{
								"source": {
									"name": "Pclass",
									"type": "String",
									"physicalType": "String"
								},
								"sink": {
									"name": "Pclass",
									"type": "Byte",
									"physicalType": "tinyint"
								}
							},
							{
								"source": {
									"name": "Name",
									"type": "String",
									"physicalType": "String"
								},
								"sink": {
									"name": "Name",
									"type": "String",
									"physicalType": "nvarchar"
								}
							},
							{
								"source": {
									"name": "Sex",
									"type": "String",
									"physicalType": "String"
								},
								"sink": {
									"name": "Sex",
									"type": "String",
									"physicalType": "nvarchar"
								}
							},
							{
								"source": {
									"name": "Age",
									"type": "String",
									"physicalType": "String"
								},
								"sink": {
									"name": "Age",
									"type": "Int32",
									"physicalType": "int"
								}
							},
							{
								"source": {
									"name": "SibSp",
									"type": "String",
									"physicalType": "String"
								},
								"sink": {
									"name": "SibSp",
									"type": "Byte",
									"physicalType": "tinyint"
								}
							},
							{
								"source": {
									"name": "Parch",
									"type": "String",
									"physicalType": "String"
								},
								"sink": {
									"name": "Parch",
									"type": "Byte",
									"physicalType": "tinyint"
								}
							},
							{
								"source": {
									"name": "Ticket",
									"type": "String",
									"physicalType": "String"
								},
								"sink": {
									"name": "Ticket",
									"type": "String",
									"physicalType": "nvarchar"
								}
							},
							{
								"source": {
									"name": "Fare",
									"type": "String",
									"physicalType": "String"
								},
								"sink": {
									"name": "Fare",
									"type": "Decimal",
									"physicalType": "decimal",
									"scale": 4,
									"precision": 10
								}
							},
							{
								"source": {
									"name": "Cabin",
									"type": "String",
									"physicalType": "String"
								},
								"sink": {
									"name": "Cabin",
									"type": "String",
									"physicalType": "nvarchar"
								}
							},
							{
								"source": {
									"name": "Embarked",
									"type": "String",
									"physicalType": "String"
								},
								"sink": {
									"name": "Embarked",
									"type": "String",
									"physicalType": "char"
								}
							}
						],
						"typeConversion": true,
						"typeConversionSettings": {
							"allowDataTruncation": true,
							"treatBooleanAsNumber": false
						}
					}
				},
				"inputs": [
					{
						"referenceName": "TitanicDEin",
						"type": "DatasetReference"
					}
				],
				"outputs": [
					{
						"referenceName": "TitanicDEout",
						"type": "DatasetReference"
					}
				]
			}
		],
		"annotations": []
	}
}