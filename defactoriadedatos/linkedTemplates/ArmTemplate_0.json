{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Nombre de instancia de Data Factory",
			"defaultValue": "defactoriadedatos"
		},
		"AzureBlobStorageDE_properties_typeProperties_serviceEndpoint": {
			"type": "string",
			"defaultValue": "https://cuentadealmacenpato.blob.core.windows.net/"
		},
		"RestServiceDE_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://pokeapi.co/api/v2/"
		},
		"AzureSqlDatabaseDE_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "deservidorsql.database.windows.net"
		},
		"AzureSqlDatabaseDE_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "debasededatos"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "[concat(parameters('factoryName'), '/AzureBlobStorageDE')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "AzureBlobStorage",
				"typeProperties": {
					"serviceEndpoint": "[parameters('AzureBlobStorageDE_properties_typeProperties_serviceEndpoint')]",
					"accountKind": "StorageV2"
				}
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/RestServiceDE')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"description": "para la api de Pokemon",
				"annotations": [],
				"type": "RestService",
				"typeProperties": {
					"url": "[parameters('RestServiceDE_properties_typeProperties_url')]",
					"enableServerCertificateValidation": true,
					"authenticationType": "Anonymous"
				}
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/credencialazure')]",
			"type": "Microsoft.DataFactory/factories/credentials",
			"apiVersion": "2018-06-01",
			"properties": {
				"type": "ManagedIdentity",
				"typeProperties": {
					"resourceId": "/subscriptions/b7c05e58-85aa-4bff-9b8c-41b13a14ef18/resourcegroups/GrupoDeRecursosDE/providers/Microsoft.ManagedIdentity/userAssignedIdentities/deidentidadadmin"
				}
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/TitanicDEin')]",
			"type": "Microsoft.DataFactory/factories/datasets",
			"apiVersion": "2018-06-01",
			"properties": {
				"linkedServiceName": {
					"referenceName": "AzureBlobStorageDE",
					"type": "LinkedServiceReference"
				},
				"annotations": [],
				"type": "DelimitedText",
				"typeProperties": {
					"location": {
						"type": "AzureBlobStorageLocation",
						"fileName": "Titanic-Dataset.csv",
						"container": "contenedorpato"
					},
					"columnDelimiter": ",",
					"escapeChar": "\\",
					"firstRowAsHeader": true,
					"quoteChar": "\""
				},
				"schema": [
					{
						"name": "PassengerId",
						"type": "String"
					},
					{
						"name": "Survived",
						"type": "String"
					},
					{
						"name": "Pclass",
						"type": "String"
					},
					{
						"name": "Name",
						"type": "String"
					},
					{
						"name": "Sex",
						"type": "String"
					},
					{
						"name": "Age",
						"type": "String"
					},
					{
						"name": "SibSp",
						"type": "String"
					},
					{
						"name": "Parch",
						"type": "String"
					},
					{
						"name": "Ticket",
						"type": "String"
					},
					{
						"name": "Fare",
						"type": "String"
					},
					{
						"name": "Cabin",
						"type": "String"
					},
					{
						"name": "Embarked",
						"type": "String"
					}
				]
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/linkedServices/AzureBlobStorageDE')]"
			]
		},
		{
			"name": "[concat(parameters('factoryName'), '/AzureSqlDatabaseDE')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "AzureSqlDatabase",
				"typeProperties": {
					"server": "[parameters('AzureSqlDatabaseDE_properties_typeProperties_server')]",
					"database": "[parameters('AzureSqlDatabaseDE_properties_typeProperties_database')]",
					"encrypt": "optional",
					"trustServerCertificate": true,
					"authenticationType": "UserAssignedManagedIdentity",
					"credential": {
						"referenceName": "credencialazure",
						"type": "CredentialReference"
					}
				}
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/credentials/credencialazure')]"
			]
		},
		{
			"name": "[concat(parameters('factoryName'), '/TitanicDEout')]",
			"type": "Microsoft.DataFactory/factories/datasets",
			"apiVersion": "2018-06-01",
			"properties": {
				"linkedServiceName": {
					"referenceName": "AzureSqlDatabaseDE",
					"type": "LinkedServiceReference"
				},
				"annotations": [],
				"type": "AzureSqlTable",
				"schema": [
					{
						"name": "PassengerId",
						"type": "int",
						"precision": 10
					},
					{
						"name": "Survived",
						"type": "bit"
					},
					{
						"name": "Pclass",
						"type": "tinyint",
						"precision": 3
					},
					{
						"name": "Name",
						"type": "nvarchar"
					},
					{
						"name": "Sex",
						"type": "nvarchar"
					},
					{
						"name": "Age",
						"type": "int",
						"precision": 10
					},
					{
						"name": "SibSp",
						"type": "tinyint",
						"precision": 3
					},
					{
						"name": "Parch",
						"type": "tinyint",
						"precision": 3
					},
					{
						"name": "Ticket",
						"type": "nvarchar"
					},
					{
						"name": "Fare",
						"type": "decimal",
						"precision": 10,
						"scale": 4
					},
					{
						"name": "Cabin",
						"type": "nvarchar"
					},
					{
						"name": "Embarked",
						"type": "char"
					}
				],
				"typeProperties": {
					"schema": "dbo",
					"table": "Titanic"
				}
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/linkedServices/AzureSqlDatabaseDE')]"
			]
		}
	]
}